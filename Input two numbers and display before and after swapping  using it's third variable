class Swap
{
    //Function to swap
    void TestingPro(int a , int b)
    {
       System.out.println("Numbers before swapping");
       System.out.println("a="+a);
       System.out.println("b="+b);
       int c=a;
       a=b;
       b=c;
       System.out.println("Numbers after swapping");
       System.out.println("a="+a);
       System.out.println("b="+b);
    }
}
